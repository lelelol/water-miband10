<template>
  <div class="page">
    <text class="title">Histórico</text>

    <div class="grid-container">
      <div class="day-box {{ item.colorClass }}" for="{{ item in days }}">
        <!-- Um quadradinho para cada dia -->
      </div>
    </div>

    <!-- ──── Legend ──── -->
    <div class="legend-row">
      <div class="legend-item">
        <div class="legend-box legend-blue"></div>
        <text class="legend-text">≥ 4L</text>
      </div>
      <div class="legend-item">
        <div class="legend-box legend-yellow"></div>
        <text class="legend-text">≥ 2L</text>
      </div>
      <div class="legend-item">
        <div class="legend-box legend-empty"></div>
        <text class="legend-text">< 2L</text>
      </div>
    </div>

    <text class="stats">Meta: {{ goalCount }} / 30 dias</text>

    <input class="back-btn" type="button" value="Voltar" onclick="goBack" />
  </div>
</template>

<style>
  .page {
    flex-direction: column;
    align-items: center;
    background-color: #000000;
  }
  .title {
    font-size: 22px;
    color: #ffffff;
    text-align: center;
    font-weight: bold;
    margin-top: 20px;
    margin-bottom: 14px;
  }
  .grid-container {
    width: 170px;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: flex-start;
  }
  .day-box {
    width: 20px;
    height: 20px;
    margin: 4px;
    border-radius: 4px;
  }
  .box-blue {
    background-color: #0088cc;
  }
  .box-yellow {
    background-color: #ccaa00;
  }
  .box-empty {
    background-color: #333333;
  }
  .legend-row {
    flex-direction: row;
    align-items: center;
    justify-content: center;
    margin-top: 14px;
    margin-bottom: 6px;
  }
  .legend-item {
    flex-direction: row;
    align-items: center;
    margin-left: 4px;
    margin-right: 4px;
  }
  .legend-box {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    margin-right: 3px;
  }
  .legend-blue { background-color: #0088cc; }
  .legend-yellow { background-color: #ccaa00; }
  .legend-empty { background-color: #333333; }
  .legend-text {
    font-size: 12px;
    color: #999999;
  }
  .stats {
    font-size: 16px;
    color: #999999;
    margin-top: 8px;
    margin-bottom: 14px;
  }
  .back-btn {
    width: 140px;
    height: 38px;
    border-radius: 19px;
    font-size: 16px;
    color: #ffffff;
    background-color: #e84057;
    text-align: center;
    font-weight: bold;
    margin-bottom: 20px;
  }
</style>

<script>
  import storage from '@system.storage'
  import router from '@system.router'

  var GOAL_ML = 4000
  var HALF_GOAL = 2000

  export default {
    private: {
      days: [],
      goalCount: 0
    },

    onInit() {
      this.loadHistory()
    },

    loadHistory() {
      var self = this
      storage.get({
        key: 'water_data',
        success: function(data) {
          var history = {}
          if (data) {
            try { history = JSON.parse(data) } catch (e) {}
          }
          self.processHistory(history)
        },
        fail: function() {
          self.processHistory({})
        }
      })
    },

    processHistory(history) {
      var today = new Date()
      today.setHours(0, 0, 0, 0)

      var newDays = []
      var count = 0
      var needsSave = false

      for (var i = 29; i >= 0; i--) {
        var d = new Date(today.getTime() - (i * 24 * 60 * 60 * 1000))
        var y = d.getFullYear()
        var m = String(d.getMonth() + 1).padStart(2, '0')
        var day = String(d.getDate()).padStart(2, '0')
        var dateString = y + '-' + m + '-' + day

        var amount = (typeof history[dateString] === 'number') ? history[dateString] : 0
        var colorClass = 'box-empty'

        if (amount >= GOAL_ML) {
          colorClass = 'box-blue'
          count++
        } else if (amount >= HALF_GOAL) {
          colorClass = 'box-yellow'
        }

        newDays.push({
          date: dateString,
          amount: amount,
          colorClass: colorClass
        })
      }

      // Garbage Collector: remove chaves com mais de 30 dias
      var thirtyDaysAgo = new Date(today.getTime() - (30 * 24 * 60 * 60 * 1000))

      var keys = Object.keys(history)
      for (var k = 0; k < keys.length; k++) {
        var keyDate = keys[k]
        try {
          var parts = keyDate.split('-')
          var kd = new Date(parts[0], parts[1] - 1, parts[2])
          kd.setHours(0, 0, 0, 0)
          if (kd.getTime() < thirtyDaysAgo.getTime()) {
            delete history[keyDate]
            needsSave = true
          }
        } catch (e) {}
      }

      if (needsSave) {
        storage.set({
          key: 'water_data',
          value: JSON.stringify(history)
        })
      }

      this.days = newDays
      this.goalCount = count
    },

    goBack() {
      router.back()
    }
  }
</script>
