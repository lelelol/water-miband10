{
  "package": "com.lelehealth.creatina",
  "name": "LeleHealth",
  "versionName": "1.0.0",
  "versionCode": 1,
  "icon": "/common/logo.png",
  "minPlatformVersion": 1000,
  "deviceTypeList": [
    "wearable",
    "watch"
  ],
  "features": [
    {
      "name": "system.router"
    },
    {
      "name": "system.vibrator"
    },
    {
      "name": "system.storage"
    },
    {
      "name": "system.fetch"
    }
  ],
  "config": {
    "logLevel": "log",
    "designWidth": 192
  },
  "router": {
    "entry": "pages/index",
    "pages": {
      "pages/index": {
        "component": "index"
      },
      "pages/history": {
        "component": "history"
      }
    }
  },
  "display": {
    "backgroundColor": "#000000",
    "fullScreen": true
  },
  "i18n": {
    "en-US": {
      "name": "LeleHealth"
    },
    "pt-BR": {
      "name": "LeleHealth"
    }
  },
  "defaultLanguage": "pt-BR"
}